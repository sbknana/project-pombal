# Itzamna / ForgeTeam — .gitignore
# Config files (generated by setup wizard, contain local paths)
forge_config.json
mcp_config.json
.mcp.json

# Databases
*.db
*.db-journal
*.db-wal
*.db-shm

# Secrets
.env
.env.*

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.venv/
venv/

# OS junk
desktop.ini
Thumbs.db
.DS_Store
nul
~$*

# IDE files
.vs/
.vscode/
.idea/
*.swp
*.swo

# Claude temp files
tmpclaude-*

# Logs
*.log
forge_orchestrator.log

# Security audit reports (contain pre-refactor vulnerability details)
SECURITY-AUDIT-REPORT.md
