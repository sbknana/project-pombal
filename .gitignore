# EQUIPA — .gitignore
# Config files (generated by setup wizard, contain local paths)
forge_config.json
mcp_config.json
.mcp.json

# Databases
*.db
*.db-journal
*.db-wal
*.db-shm

# Secrets
.env
.env.*
!.env.example

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.venv/
venv/

# OS junk
desktop.ini
Thumbs.db
.DS_Store
nul
~$*

# IDE files
.vs/
.vscode/
.idea/
*.swp
*.swo

# Claude temp files
tmpclaude-*

# Logs
*.log
forge_orchestrator.log
forgesmith.log

# ForgeSmith runtime data
.forgesmith-backups/
.forge-checkpoints/

# Agent state persistence (anti-compaction, ephemeral working state)
.forge-state.json

# Security audit reports (contain pre-refactor vulnerability details)
SECURITY-AUDIT-REPORT.md

# Security review reports (project-specific, contain vulnerability details)
SECURITY-REVIEW-*.md

# Autoresearch backups (prompt mutation history)
.autoresearch-backups/

# Training data (generated, may contain project-specific content)
*.jsonl

# Local Claude settings
.claude/settings.local.json

# Project manifest (generated by Athena)
project-manifest.json

# Semgrep cache
.semgrep/

# Dispatch config (contains local paths/settings)
dispatch_config.json


# Training scripts (Forgeborn-specific, not for public repo)
train_qlora*.py

# Local config (users create from .example files)
forge_config.json
dispatch_config.json
mcp_config.json
forgesmith_config.json

# EQUIPA agent task output artifacts (auto-generated summaries)
*-[0-9][0-9][0-9][0-9].md
SPLIT-PHASE*.md
ANTI-COMPACTION-*.md
LANG-PROMPTS-*.md
FEATURE-FLAGS-*.md
TEST-*.md
INTEGRATION-TEST-*.md
MODULE-DEPS-*.md
QVALUE-FEEDBACK-*.md
GEPA-EPISODE-CHECK-*.md
SIMBA-EPISODE-BIAS-*.md
INSTALL-TEST-*.md
NARRATIONS-*.md
RESEED-DATA-*.md
FONT-SIZE-*.md
QA-WYSIWYG-*.md
NEW-CUSTOMER-INLINE-*.md
WYSIWYG-EDITOR-*.md

# Skill manifest (auto-generated, regenerate with --regenerate-manifest)
skill_manifest.json

# Internal project context (not user-facing documentation)
CLAUDE.md

# Pytest cache
.pytest_cache/

# Research/analysis reports (internal, not documentation)
ecc-vs-equipa-analysis.md
LANDSCAPE-REPORT-*.md
MONOLITH-SPLIT-PLAN.md
ECC-IMPLEMENTATION-PLAN.md
docs-config.json
tmp-*.md

# Generated files
project-manifest.json
skill_manifest.json
docs-config.json
docs/html/
